# OpenClaw 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ======================
# 服务器配置
# ======================
SERVER_IP=134.175.176.7
SSH_USER=devuser
SSH_PASSWORD=DevPass123!
SSH_PORT=22

# ======================
# 服务端口配置
# ======================
FASTAPI_PORT=9000
HTTP_PORT=8080
HTTPS_PORT=8443
MONITOR_PORT=9001

# ======================
# 部署目录配置
# ======================
DEPLOY_DIR=/opt/openclaw
OPENCLAW_REPO=https://github.com/xg-ai/openclaw.git

# ======================
# Tushare Pro 配置
# ======================
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_PRO_URL=http://api.tushare.pro

# ======================
# 数据库配置 (如果需要)
# ======================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=openclaw
# DB_USER=openclaw_user
# DB_PASSWORD=your_db_password

# ======================
# JWT 配置 (如果需要)
# ======================
# JWT_SECRET=your_jwt_secret_key_here
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION=3600

# ======================
# 日志配置
# ======================
LOG_LEVEL=INFO
LOG_FILE=/opt/openclaw/logs/openclaw.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=10